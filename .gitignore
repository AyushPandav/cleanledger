# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Expo ─────────────────────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ─── Native Build Outputs ─────────────────────────────────────────────────────
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
/ios
/android

# ─── Metro Bundler ────────────────────────────────────────────────────────────
.metro-health-check*

# ─── Debug Logs ───────────────────────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
logs/

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── OS Artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.pem

# ─── Editor & IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo

# ─── Python AI Backend (ai_backend/) ──────────────────────────────────────────
ai_backend/venv/
ai_backend/__pycache__/
ai_backend/*.pyc
ai_backend/*.pyo
ai_backend/*.pyd
ai_backend/.Python
ai_backend/*.egg-info/
ai_backend/dist/
ai_backend/build/
ai_backend/.pytest_cache/
ai_backend/.mypy_cache/
ai_backend/htmlcov/
ai_backend/.coverage

# ─── Miscellaneous ────────────────────────────────────────────────────────────
app-example
*.bak
*.tmp
.cache/
